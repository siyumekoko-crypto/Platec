@{
    var role = Context.Session.GetString("UserRole"); // "1" or "2"
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Platec</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", Arial, sans-serif;
            background: #f1f3f7;
        }

        /* TOP NAVBAR */
        .top-navbar {
            height: 65px;
            background: #95B2E7;
            border-bottom: 1px solid #e5e9f2;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
        }

        .logo {
            font-size: 22px;
            font-weight: 700;
            color: #012970;
            text-decoration: none;
        }

        /* MAIN LAYOUT */
        .main-wrapper {
            display: flex;
            min-height: calc(100vh - 65px);
        }

        /* SIDEBAR */
        .sidebar {
            width: 240px;
            background: white;
            border-right: 1px solid #e5e9f2;
            display: flex;
            flex-direction: column;
        }

            .sidebar .nav-link {
                padding: 15px 25px;
                font-size: 16px;
                color: #012970;
                font-weight: 500;
            }

                .sidebar .nav-link:hover {
                    background: #f5f7ff;
                    color: #012970;
                }

        .dropdown-hover {
            position: relative;
        }

        .dropdown-menu-custom {
            display: none;
            flex-direction: column;
        }

        .dropdown-hover:hover .dropdown-menu-custom {
            display: block;
        }

        .dropdown-item {
            padding: 12px 45px;
            color: #012970;
        }

            .dropdown-item:hover {
                background: #eef2ff;
                color: #012970;
            }

        .logout-area {
            padding: 20px;
        }

        /* CONTENT */
        .content {
            flex-grow: 1;
            padding: 35px 40px;
        }

            .content header h4 {
                margin-bottom: 3px;
            }

        .breadcrumb {
            font-size: 13px;
            color: #8a94a6;
        }

    </style>
</head>
<body>

    <!-- TOP NAVBAR -->
    <div class="top-navbar">
        <a class="logo" asp-controller="Admin" asp-action="Index">
            Platec
        </a>
        <!-- Optional: Add user info / avatar here -->
    </div>

    <!-- MAIN LAYOUT -->
    <div class="main-wrapper">

        <!-- SIDEBAR -->
        <div class="sidebar">

            <nav class="nav flex-column mt-3">

                <a class="nav-link" asp-controller="Admin" asp-action="Index">Dashboard</a>

                @if (role == "Admin" || role == "1")
                {
                    <div class="nav-item dropdown-hover">
                        <a class="nav-link">User Management</a>
                        <div class="dropdown-menu-custom">
                            <a class="dropdown-item" asp-controller="Registration" asp-action="StudentManagement">
                                Student Management
                            </a>
                            <a class="dropdown-item" asp-controller="Registration" asp-action="Index">
                                Admin Management
                            </a>
                        </div>
                    </div>

                    <a class="nav-link" asp-controller="Courses" asp-action="Index">Courses</a>
                }
                else
                {
                    <a class="nav-link" asp-controller="Registration" asp-action="StudentManagement">
                        Student Management
                    </a>

                    <a class="nav-link" asp-controller="Class" asp-action="Index">Classes</a>

                }

                <a class="nav-link" asp-controller="Report" asp-action="Index">Reports</a>

            </nav>

            <!-- Logout -->
            <div class="mt-auto logout-area">
                <a class="btn btn-danger w-100" asp-controller="LogIn" asp-action="Index">
                    Logout
                </a>
            </div>

        </div>

        <!-- PAGE CONTENT -->
        <div class="content">
            <header class="mb-3">
                <h4>@ViewData["Title"]</h4>
                <div class="breadcrumb">
                    Home / @ViewData["Title"]
                </div>
            </header>

            <main role="main">
                @RenderBody()
            </main>
        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>