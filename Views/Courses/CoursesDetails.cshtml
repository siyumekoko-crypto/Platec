@model Platec.Models.Course

@{
    ViewData["Title"] = "Course Details";
}

<div class="container mt-4">
    <h2>@Model.CourseName</h2>
    <hr />

<p>
    <strong>Teacher:</strong>
    @(Model.Teacher != null ? Model.Teacher.Email : "None")
</p>

    <form asp-action="SetTeacher" method="post" class="mt-3">
        <input type="hidden" name="CourseId" value="@Model.CourseId" />

        <div class="form-group mb-2">
            <label asp-for="TeacherId">Assign Teacher</label>
            <select class="form-control" asp-for="TeacherId" asp-items="ViewBag.TeacherList" required>
                <option value="">-- Select Teacher --</option>
            </select>
        </div>

        <button type="submit" class="btn btn-primary">
            @(Model.Teacher != null ? "Change Teacher" : "Set Teacher")
        </button>
    </form>

    <p>
        <strong>Students Enrolled:</strong> @Model.Students.Count
    </p>

    @if (Model.Students.Any())
    {
        <div class="mt-4">
            <h4>Attendance Sheet</h4>

            <form asp-action="SaveAttendance" method="post">

                <input type="hidden" name="CourseId" value="@Model.CourseId" />

                <!-- Date Picker -->
                <div class="card shadow-sm mb-4">
                    <div class="card-body d-flex justify-content-between align-items-center flex-wrap">

                        <div>
                            <h5 class="mb-1">Select Attendance Date</h5>
                            <small class="text-muted">Choose date to record attendance</small>
                        </div>

                        <div>
                            <input type="date"
                                   name="AttendanceDate"
                                   class="form-control"
                                   style="min-width: 220px;"
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")"
                                   required />
                        </div>

                    </div>
                </div>

                <!-- Table -->
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle text-center">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Student Name</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int count = 1;
                            }
@foreach (var student in Model.Students)
{
    var todaysAttendance = ViewBag.TodaysAttendance as List<ClassStatus>;
    var existingStatus = todaysAttendance?.FirstOrDefault(a => a.StudentId == student.ID);

    <tr>
        <td>@count</td>
        <td class="text-start">
            @student.LastName, @student.FirstName
        </td>
        <td>
            <input type="hidden" name="StudentIds" value="@student.ID" />

            <select name="Statuses" class="form-select form-select-sm" required>
                <option value="">-- Select --</option>

                @if (existingStatus?.Status == "Present")
                {
                    <option value="Present" selected>Present</option>
                }
                else
                {
                    <option value="Present">Present</option>
                }

                @if (existingStatus?.Status == "Absent")
                {
                    <option value="Absent" selected>Absent</option>
                }
                else
                {
                    <option value="Absent">Absent</option>
                }

                @if (existingStatus?.Status == "Late")
                {
                    <option value="Late" selected>Late</option>
                }
                else
                {
                    <option value="Late">Late</option>
                }

            </select>
        </td>
    </tr>

    count++;
}


                        </tbody>
                    </table>
                </div>

                <div class="mt-3 text-end">
                    <button type="submit" class="btn btn-success">
                        Save Attendance
                    </button>
                </div>

            </form>
        </div>
    }

    else
    {
        <p class="text-muted mt-3">No students enrolled.</p>
    }

    <div class="mt-4">
        <a asp-action="Edit"
           asp-route-id="@Model.CourseId"
           class="btn btn-warning">
            Edit Course
        </a>

        <a asp-action="Index"
           class="btn btn-secondary ms-2">
            Back to Courses
        </a>
    </div>
</div>

