@model Platec.Models.Course

@{
    ViewData["Title"] = "Course Details";
    var role = Context.Session.GetString("UserRole");
}

<div class="container mt-4">

    <!-- Course Info Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">

            <h3 class="card-title fw-bold">@Model.CourseName</h3>
            <hr />

            <p>
                <strong>Teacher:</strong>
                @(Model.Teacher != null ? Model.Teacher.Email : "None")
            </p>

            <p>
                <strong>Students Enrolled:</strong> @Model.Students.Count
            </p>

            @if (role == "Admin")
            {
                <form asp-action="SetTeacher" method="post" class="mt-3 d-flex align-items-end gap-2 flex-wrap">

                    <input type="hidden" name="CourseId" value="@Model.CourseId" />

                    <div class="form-group d-flex align-items-end gap-2 flex-wrap">

                        <div>
                            <label asp-for="TeacherId" class="form-label fw-semibold">Assign Teacher</label>

                            <select class="form-control"
                                    asp-for="TeacherId"
                                    asp-items="ViewBag.TeacherList"
                                    style="min-width:220px;"
                                    required>

                                <option value="">-- Select Teacher --</option>

                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            @(Model.Teacher != null ? "Change Teacher" : "Set Teacher")
                        </button>

                    </div>

                </form>
            }

        </div>
    </div>


    @if (Model.Students.Any())
    {

        <div class="card shadow-sm mb-4">

            <div class="card-body">

                <form asp-action="SaveAttendance" method="post">

                    <input type="hidden" name="CourseId" value="@Model.CourseId" />

                    <!-- Date Picker -->

                    <div class="card-body d-flex justify-content-between align-items-center flex-wrap">

                        <div>
                            <h4 class="fw-bold mb-3">Attendance Sheet</h4>
                        </div>

                        <div>

                            <input type="date"
                                   name="AttendanceDate"
                                   class="form-control"
                                   style="min-width:220px;"
                                   value="@ViewBag.AttendanceDate"
                                   onchange="changeDate(this)"
                                   required />

                        </div>

                    </div>

                    <hr />

                    <!-- Attendance Table -->

                    <div class="table-responsive">

                        <table class="table table-hover align-middle text-center attendance-table">

                            <thead>

                                <tr>
                                    <th>#</th>
                                    <th class="text-start">Student Name</th>
                                    <th>Status</th>
                                </tr>

                            </thead>

                            <tbody>

                                @{
                                    int count = 1;
                                }

                                @foreach (var student in Model.Students)
                                {

                                    var todaysAttendance = ViewBag.TodaysAttendance as List<ClassStatus>;
                                    var existingStatus = todaysAttendance?.FirstOrDefault(a => a.StudentId == student.ID);

                                    <tr>

                                        <td>@count</td>

                                        <td class="text-start fw-semibold">
                                            @student.LastName, @student.FirstName
                                        </td>

                                        <td>

                                            <input type="hidden" name="StudentIds" value="@student.ID" />

                                            <select name="Statuses"
                                                    class="form-select form-select-sm"
                                                    required>

                                                <option value="">-- Select --</option>

                                                @if (existingStatus?.Status == "Present")
                                                {
                                                    <option value="Present" selected>Present</option>
                                                }
                                                else
                                                {
                                                    <option value="Present">Present</option>
                                                }

                                                @if (existingStatus?.Status == "Absent")
                                                {
                                                    <option value="Absent" selected>Absent</option>
                                                }
                                                else
                                                {
                                                    <option value="Absent">Absent</option>
                                                }

                                                @if (existingStatus?.Status == "Late")
                                                {
                                                    <option value="Late" selected>Late</option>
                                                }
                                                else
                                                {
                                                    <option value="Late">Late</option>
                                                }

                                            </select>

                                        </td>

                                    </tr>

                                    count++;

                                }

                            </tbody>

                        </table>

                    </div>

                    <div class="mt-3 text-end">

                        <button type="submit" class="btn btn-success">
                            Save Attendance
                        </button>

                        <a asp-action="Index"
                           class="btn btn-secondary ms-2">
                            Back to Courses
                        </a>

                    </div>

                </form>

            </div>

        </div>

    }
    else
    {

        <div class="card shadow-sm">

            <div class="card-body text-muted">
                No students enrolled.
            </div>

        </div>

    }

</div>



<script>
    function changeDate(input) {
        var selectedDate = input.value;
        var courseId = '@Model.CourseId';

        window.location.href = '/Courses/CoursesDetails?id=' + courseId + '&date=' + selectedDate;
    }
</script>



<style>

    .card {
        border-radius: 12px;
        border: none;
    }

    .card-title {
        color: #2c3e50;
    }

    .date-card {
        background: linear-gradient(135deg,#4e73df,#224abe);
        border-radius: 12px;
    }

    .attendance-table thead {
        background: #343a40;
        color: white;
    }

    .attendance-table tbody tr:hover {
        background: #f5f7ff;
    }

    .btn-primary {
        background: #4e73df;
        border: none;
    }

        .btn-primary:hover {
            background: #2e59d9;
        }

    .btn-success {
        background: #1cc88a;
        border: none;
    }

        .btn-success:hover {
            background: #17a673;
        }

    .form-select {
        border-radius: 8px;
    }

    .form-control {
        border-radius: 8px;
    }

</style>